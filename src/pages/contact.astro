---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Contact Blue Cap IT | Managed IT, Cybersecurity & Security — (410) 858-4031" description="Contact Blue Cap IT for managed IT services, cybersecurity, and Verkada security solutions. Call (410) 858-4031 or email info@bluecapit.com.">
  <div class="inner-hero">
    <div class="section-inner">
      <div class="crumbs"><a href="index.html">Home</a> <span>/</span> Contact</div>
      <div class="section-label">Get in Touch</div>
      <h1>Let's Talk <span class="grad">Technology.</span></h1>
      <p class="section-sub">Reach out for a free consultation on managed IT services, cybersecurity, or physical security solutions. We respond fast — because your business matters.</p>
    </div>
  </div>

  <section>
    <div class="section-inner">
      <div class="contact-grid">
        <div>
          <div class="section-label">Contact Information</div>
          <h2 style="margin-bottom:1.5rem;">Blue Cap IT<br/><span class="grad">Is Here to Help.</span></h2>
          <div class="contact-detail"><span class="ci">📞</span><div><div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.2rem;">Phone</div><a href="tel:4108584031">(410) 858-4031</a></div></div>
          <div class="contact-detail"><span class="ci">🌐</span><div><div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.2rem;">Website</div><a href="https://bluecapit.com">bluecapit.com</a></div></div>
          <div class="contact-detail"><span class="ci">📧</span><div><div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.2rem;">Email</div><a href="mailto:info@bluecapit.com">info@bluecapit.com</a></div></div>
          <div class="contact-detail"><span class="ci">★</span><div><div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.2rem;">Partner Status</div><span style="color:var(--blue);font-weight:600;">MSP &bull; Coro Partner &bull; Huntress Partner &bull; Verkada Gold Partner &bull; Meter Partner</span></div></div>

          <div style="margin-top:2.5rem;padding:1.8rem;background:rgba(30,111,230,0.08);border:1px solid rgba(30,111,230,0.2);border-radius:14px;">
            <div style="font-family:'Sora',sans-serif;font-weight:700;font-size:1rem;margin-bottom:0.7rem;">🚀 What to Expect</div>
            <ul class="feature-bullets">
              <li>Free, no-obligation consultation</li>
              <li>Site assessment &amp; system design</li>
              <li>Detailed itemized quote</li>
              <li>Professional installation scheduling</li>
              <li>Ongoing support after go-live</li>
            </ul>
          </div>
        </div>

        <div>
          <div style="background:var(--card-bg);border:1px solid var(--border);border-radius:20px;padding:2.5rem;">
            <div style="font-family:'Sora',sans-serif;font-weight:700;font-size:1.1rem;margin-bottom:0.4rem;">Request a Free Quote</div>
            <div style="font-size:0.84rem;color:var(--text-muted);margin-bottom:2rem;">We'll get back to you within one business day.</div>
            <form class="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
              <input type="hidden" name="form-name" value="contact" />
              <p style="display:none;"><label>Don't fill this out: <input name="bot-field" /></label></p>
              <div class="form-row">
                <input type="text" name="first-name" placeholder="First Name" required/>
                <input type="text" name="last-name" placeholder="Last Name" required/>
              </div>
              <input type="email" name="email" placeholder="Email Address" required/>
              <input type="tel" name="phone" placeholder="Phone Number"/>
              <input type="text" name="company" placeholder="Company / Organization"/>
              <select name="interest">
                <option value="" disabled selected>What are you interested in?</option>
                <optgroup label="Managed IT Services">
                  <option>Managed IT Services (Full Package)</option>
                  <option>Helpdesk &amp; Support</option>
                  <option>Backup &amp; Disaster Recovery</option>
                  <option>Microsoft 365 Management</option>
                  <option>Network Management</option>
                  <option>Virtual CIO (vCIO) Services</option>
                </optgroup>
                <optgroup label="Cybersecurity — Coro">
                  <option>Coro Cybersecurity (Full Platform)</option>
                  <option>Endpoint Protection</option>
                  <option>Email Security</option>
                  <option>Security Awareness Training</option>
                </optgroup>
                <optgroup label="Physical Security — Verkada">
                  <option>Video Security Cameras</option>
                  <option>Access Control</option>
                  <option>Environmental Sensors</option>
                  <option>Alarms &amp; Intrusion</option>
                  <option>Intercom &amp; Visitor Management</option>
                  <option>Full Verkada System (Multiple Products)</option>
                </optgroup>
                <optgroup label="Managed Security — Huntress">
                  <option>Huntress (Full Platform)</option>
                  <option>Managed EDR</option>
                  <option>Managed ITDR (Identity Threats)</option>
                  <option>Managed SIEM</option>
                  <option>Security Awareness Training (Huntress SAT)</option>
                </optgroup>
                <optgroup label="Networking — Meter">
                  <option>Meter Networking (Full Solution)</option>
                  <option>Switches</option>
                  <option>Wi-Fi Access Points</option>
                  <option>Firewalls</option>
                  <option>5G Gateway</option>
                </optgroup>
                <option>General Inquiry</option>
              </select>
              <textarea name="message" placeholder="Tell us about your needs — managed IT, cybersecurity, physical security, number of users/locations, or any specific requirements..."></textarea>
              <button type="submit">Send My Request →</button>
            </form>
            <div id="form-success" style="display:none;text-align:center;padding:2rem;color:var(--blue);">
              <div style="font-size:2rem;margin-bottom:0.7rem;">✅</div>
              <div style="font-family:'Sora',sans-serif;font-weight:700;">Message Sent!</div>
              <div style="color:var(--text-muted);font-size:0.85rem;margin-top:0.4rem;">We'll be in touch within one business day.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
