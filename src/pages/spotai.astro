---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="spot.ai Video Intelligence | Blue Cap IT — spot.ai Partner" description="Blue Cap IT partners with spot.ai to deliver AI-powered video intelligence. Camera-agnostic platform with intelligent video recording, real-time alerts, and deep-learning analytics that turn your cameras into business tools.">
  <div class="inner-hero">
    <div class="section-inner">
      <div class="crumbs"><a href="index.html">Home</a> <span>/</span> spot.ai</div>
      <div class="section-label">spot.ai Partner</div>
      <h1>Video Intelligence. <span class="grad">Powered by AI.</span></h1>
      <p class="section-sub">Blue Cap IT partners with spot.ai to transform your cameras from passive recording devices into active AI teammates. The spot.ai platform uses deep learning to detect events, surface insights, and alert your team in real time — turning every camera into a business tool.</p>
    </div>
  </div>

  <!-- SPOT AI LOGO -->
  <section>
    <div class="section-inner" style="text-align:center;padding:2rem 1.5rem;">
      <img src="/spotai/spotai-logo.png" alt="spot.ai" style="max-height:60px;width:auto;"/>
    </div>
  </section>

  <!-- WHY SPOT AI -->
  <section>
    <div class="section-inner">
      <div class="why-grid">
        <div>
          <div class="section-label">Why spot.ai</div>
          <h2>Your Cameras Are Smarter<br/><span class="grad">Than You Think.</span></h2>
          <p class="section-sub">Most businesses have cameras that just record. spot.ai makes them intelligent — automatically detecting safety incidents, spotting operational bottlenecks, recognizing license plates, and surfacing insights you'd never find manually. And it works with your existing cameras.</p>
          <p class="section-sub" style="margin-top:1rem;">As a spot.ai Partner, Blue Cap IT deploys the full platform for you — the Intelligent Video Recorder, AI cameras, cloud dashboard, and integrations — so you get video intelligence without the complexity.</p>
          <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
            <a href="contact.html" class="btn-primary">Get a Free Quote</a>
            <a href="tel:4108584031" class="btn-ghost">Call (410) 858-4031</a>
          </div>
        </div>
        <ul class="why-list">
          <li class="why-item">
            <div class="why-icon">🧠</div>
            <div><h4>AI-Powered Analytics</h4><p>Deep-learning models classify people, vehicles, forklifts, and assets — then apply rules for counting, anomaly detection, and trend reporting automatically.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon">📷</div>
            <div><h4>Camera Agnostic</h4><p>Works with your existing IP cameras. No need to rip and replace — the Intelligent Video Recorder upgrades any ONVIF-compliant camera with AI capabilities.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon">☁️</div>
            <div><h4>Hybrid Cloud Architecture</h4><p>Local edge processing for speed and reliability, plus cloud access for remote viewing, search, and management from anywhere.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon">🔌</div>
            <div><h4>Powerful Integrations</h4><p>Connect video with access control, POS systems, environmental sensors, and more — converging real-time video with contextual business data.</p></div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- PRODUCT LINES -->
  <section style="background:var(--surface);">
    <div class="section-inner">
      <div style="text-align:center;max-width:640px;margin:0 auto 2rem;">
        <div class="section-label">spot.ai Platform</div>
        <h2>Complete Video <span class="grad">Intelligence.</span></h2>
        <p class="section-sub" style="margin:0.8rem auto 0;text-align:center;">From cameras and recording to AI analytics and real-time alerts — spot.ai delivers a complete platform that makes your video footage actionable.</p>
      </div>
      <div class="products-grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr));max-width:1000px;margin:0 auto;">
        <a href="spotai-cameras.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">📷</div>
          <h3>AI Cameras</h3>
          <p>Premium IP cameras included at no cost, or use your existing cameras. spot.ai is fully camera-agnostic and works with any ONVIF-compliant device.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="spotai-ivr.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">💾</div>
          <h3>Intelligent Video Recorder</h3>
          <p>The brain of the system. Purpose-built hardware that auto-discovers cameras, encrypts footage, and runs deep-learning AI models at the edge.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="spotai-video-intelligence.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">🧠</div>
          <h3>Video Intelligence</h3>
          <p>AI-powered search, object detection, people counting, license plate recognition, and trend reporting — all from your existing camera footage.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="spotai-alerts.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">🔔</div>
          <h3>Real-Time Alerts</h3>
          <p>Instant notifications for security incidents, safety violations, operational anomalies, and custom triggers — delivered to your team in real time.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- USE CASES -->
  <section>
    <div class="section-inner">
      <div style="text-align:center;max-width:640px;margin:0 auto 2rem;">
        <div class="section-label">Use Cases</div>
        <h2>Beyond Security. <span class="grad">Business Intelligence.</span></h2>
        <p class="section-sub" style="margin:0.8rem auto 0;text-align:center;">spot.ai turns cameras into tools for safety, operations, compliance, and customer experience — not just security.</p>
      </div>
      <div class="products-grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));">
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon">🛡️</div>
          <h3>Security &amp; Safety</h3>
          <p>Detect intrusions, monitor restricted areas, verify alarms, and investigate incidents with AI-powered search.</p>
        </div>
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon">🏭</div>
          <h3>Operations</h3>
          <p>Monitor workflows, identify bottlenecks, track vehicle idle time, and optimize processes with video analytics.</p>
        </div>
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon">⚠️</div>
          <h3>Workplace Safety</h3>
          <p>Detect PPE violations, monitor hazardous areas, track slip-and-fall events, and ensure compliance with safety protocols.</p>
        </div>
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon">🏪</div>
          <h3>Retail &amp; Customer</h3>
          <p>People counting, traffic flow analysis, queue monitoring, and loss prevention powered by AI video analytics.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--surface);">
    <div class="section-inner" style="text-align:center;padding:4rem 1.5rem;">
      <div class="section-label">Get Started</div>
      <h2>Ready for <span class="grad">Smarter Video?</span></h2>
      <p class="section-sub" style="max-width:600px;margin:0.8rem auto 2rem;text-align:center;">Contact Blue Cap IT for a free video intelligence assessment. We'll evaluate your current camera system and show you how spot.ai can turn your footage into actionable insights.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="contact.html" class="btn-primary">Get a Free Quote</a>
        <a href="tel:4108584031" class="btn-ghost">Call (410) 858-4031</a>
      </div>
    </div>
  </section>
</MainLayout>
