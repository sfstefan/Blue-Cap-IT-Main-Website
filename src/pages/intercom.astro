---
import MainLayout from '../layouts/MainLayout.astro';
import { Icon } from 'astro-icon/components';
---
<MainLayout title="Verkada Intercom &amp; Visitor Management | Blue Cap IT — Gold Partner" description="Verkada video intercoms with two-way audio, remote unlock, and digital visitor check-in. Cloud-managed intercom and visitor management through Blue Cap IT.">
  <div class="inner-hero">
    <div class="section-inner">
      <div class="crumbs"><a href="index.html">Home</a> <span>/</span> <a href="verkada.html">Verkada Solutions</a> <span>/</span> Intercom &amp; Visitor Management</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;">
        <div>
          <div class="section-label">Verkada Solution</div>
          <h1>Intercom &amp; <span class="grad">Visitor Management</span></h1>
          <p class="section-sub">Smart video intercoms with two-way audio and remote unlock. Digitize your visitor experience with cloud-managed check-in and host notifications.</p>
          <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
            <a href="contact.html" class="btn-primary">Get an Intercom Quote</a>
            <a href="tel:4108584031" class="btn-ghost btn-sm"><Icon name="lucide:phone" /> (410) 858-4031</a>
          </div>
        </div>
        <img src="/240919_Intercom_SH050_Trio_ALT_005_web_Still0176.png" alt="Verkada Intercoms" class="feature-img"/>
      </div>
    </div>
  </div>

  <section>
    <div class="section-inner">
      <div class="products-grid">
        <div class="product-card"><div class="pcard-icon"><Icon name="lucide:video" /></div><h3>Video Intercom</h3><p>HD camera built into every Verkada intercom device. See and speak with visitors clearly before granting access — from your phone or desktop.</p></div>
        <div class="product-card"><div class="pcard-icon"><Icon name="lucide:lock-open" /></div><h3>Remote Unlock</h3><p>Unlock any door remotely from the Verkada mobile app. Hosts can grant access to expected visitors without leaving their desk.</p></div>
        <div class="product-card"><div class="pcard-icon"><Icon name="lucide:clipboard-list" /></div><h3>Digital Visitor Check-In</h3><p>Visitors self-check-in on an iPad kiosk, sign NDA documents, take a photo badge, and notify their host automatically — no receptionist required.</p></div>
        <div class="product-card"><div class="pcard-icon"><Icon name="lucide:bell" /></div><h3>Host Notifications</h3><p>When a visitor arrives, the host receives an instant push notification with the visitor's name, photo, and a one-tap unlock button.</p></div>
        <div class="product-card"><div class="pcard-icon"><Icon name="lucide:bar-chart-3" /></div><h3>Visitor Logs &amp; Reports</h3><p>Every visitor check-in is logged with timestamp, photo, signed documents, and host details. Fully searchable visitor history for compliance.</p></div>
        <div class="product-card"><div class="pcard-icon"><Icon name="lucide:link" /></div><h3>Access Control Integration</h3><p>Intercoms integrate natively with Verkada access control — issue temporary QR code credentials to pre-approved visitors automatically.</p></div>
      </div>
    </div>
  </section>


  <section class="specs-section">
    <div class="section-inner">
      <div class="section-label">Hardware</div>
      <h2>Intercom <span class="grad">Hardware</span></h2>
      <div class="specs-grid">
        <div class="spec-card">
          <img src="/verkada/intercom/family-set.png" alt="Intercom Family Set" style="width:100%;border-radius:0.5rem;margin-bottom:0.75rem;" />
          <h4>Video Intercoms</h4>
          <p>HD camera, two-way audio, built-in card reader, weatherproof design.</p>
        </div>
        <div class="spec-card">
          <img src="/verkada/intercom/blue-light-tower.png" alt="Blue Light Emergency Tower" style="width:100%;border-radius:0.5rem;margin-bottom:0.75rem;" />
          <h4>Emergency Blue Light Tower</h4>
          <p>Highly visible emergency stations, one-touch calling, built-in camera, ideal for campuses and parking structures.</p>
        </div>
        <div class="spec-card">
          <img src="/verkada/intercom/receivers.png" alt="Intercom Receivers" style="width:100%;border-radius:0.5rem;margin-bottom:0.75rem;" />
          <h4>Desk & Wall Receivers</h4>
          <p>Indoor stations for reception desks, two-way audio and video, instant door unlock capability.</p>
        </div>
      </div>
    </div>
  </section>

<div class="cta-band">
    <div class="section-label">Modernize Your Entry Experience</div>
    <h2>Professional Intercom Systems<br/><span class="grad">Installed by Blue Cap IT</span></h2>
    <div class="btn-group">
      <a href="contact.html" class="btn-primary">Request a Free Quote</a>
      <a href="tel:4108584031" class="btn-ghost"><Icon name="lucide:phone" /> (410) 858-4031</a>
      <a href="mailto:info@bluecapit.com" class="btn-ghost"><Icon name="lucide:mail" /> info@bluecapit.com</a>
    </div>
  </div>
</MainLayout>
