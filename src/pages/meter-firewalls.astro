---
import MainLayout from '../layouts/MainLayout.astro';
import { Icon } from 'astro-icon/components';
---
<MainLayout title="Meter Firewalls | Blue Cap IT — Meter Partner" description="Meter's in-house designed firewalls provide enterprise-grade network security with automatic failover, deep integration, and cloud management. No complexity, no extra vendors.">
  <div class="inner-hero">
    <div class="section-inner">
      <img src="/meter/Meter-purple.png" alt="Meter" style="max-height:60px;width:auto;margin-bottom:1.5rem;"/>
      <div class="crumbs"><a href="index.html">Home</a> <span>/</span> <a href="meter.html">Networking</a> <span>/</span> Firewalls</div>
      <div class="section-label">Meter Hardware</div>
      <h1>Meter <span class="grad">Firewalls</span></h1>
      <p class="section-sub">Enterprise-grade network security built in-house by Meter. Automatic failover, deep packet inspection, and seamless integration with your entire Meter network — no third-party appliances, no extra vendors, no configuration headaches.</p>
    </div>
  </div>

  <!-- FIREWALL FEATURES -->
  <section>
    <div class="section-inner">
      <div class="why-grid">
        <div>
          <div class="section-label">F-Series Firewalls</div>
          <h2>Security That <span class="grad">Just Works.</span></h2>
          <p class="section-sub">Meter's F-Series firewalls are designed and manufactured in-house to integrate seamlessly with every other component in your Meter network — switches, access points, gateways, and software. No bolt-on appliances. No compatibility issues. Just comprehensive network security that's configured, monitored, and managed for you.</p>
          <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
            <a href="contact.html" class="btn-primary">Get a Free Quote</a>
            <a href="tel:4108584031" class="btn-ghost">Call (410) 858-4031</a>
          </div>
        </div>
        <ul class="why-list">
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:refresh-cw" /></div>
            <div><h4>Automatic Failover</h4><p>Redundant firewall pairs ensure your network stays protected even if one unit goes down. Failover happens automatically — no manual intervention, no downtime.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:lock" /></div>
            <div><h4>Deep Packet Inspection</h4><p>Inspect traffic at the application layer to detect and block threats, malware, and unauthorized activity before it reaches your network.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:globe" /></div>
            <div><h4>DNS Security</h4><p>Block malicious domains and filter web traffic at the DNS level — stopping threats before they even establish a connection.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:key-round" /></div>
            <div><h4>VPN &amp; SD-WAN</h4><p>Secure site-to-site and remote access VPN built into the firewall. SD-WAN capabilities route traffic intelligently across multiple WAN connections.</p></div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FIREWALL MODELS -->
  <section style="background:var(--surface);">
    <div class="section-inner">
      <div style="text-align:center;max-width:640px;margin:0 auto 2rem;">
        <div class="section-label">F-Series Models</div>
        <h2>Three Firewalls. <span class="grad">Every Scale.</span></h2>
      </div>
      <div class="products-grid">
        <div class="product-card">
          <img src="/meter/hw-f1.webp" alt="Meter F1 Firewall" style="width:100%;border-radius:0.75rem;margin-bottom:1rem;" />
          <h3>F1 — 50 Gbps Firewall</h3>
          <p>Meter's highest-capacity firewall, delivering 50 Gbps throughput in a high-availability dual-unit configuration for large enterprise environments.</p>
          <ul style="margin-top:1rem;padding-left:1.2rem;font-size:0.92rem;color:var(--muted);">
            <li>50 Gbps WAN throughput</li>
            <li>High-availability dual-unit design</li>
            <li>Automatic failover</li>
            <li>Built for large campuses and HQs</li>
          </ul>
        </div>
        <div class="product-card">
          <img src="/meter/hw-f2.webp" alt="Meter F2 Firewall" style="width:100%;border-radius:0.75rem;margin-bottom:1rem;" />
          <h3>F2 — 20 Gbps Firewall</h3>
          <p>High-availability dual firewall with 20 Gbps throughput. The sweet spot for mid-size offices and multi-site deployments.</p>
          <ul style="margin-top:1rem;padding-left:1.2rem;font-size:0.92rem;color:var(--muted);">
            <li>20 Gbps WAN throughput</li>
            <li>High-availability dual-unit design</li>
            <li>Automatic failover</li>
            <li>Ideal for mid-size offices</li>
          </ul>
        </div>
        <div class="product-card">
          <img src="/meter/hw-f3.webp" alt="Meter F3 Firewall" style="width:100%;border-radius:0.75rem;margin-bottom:1rem;" />
          <h3>F3 — Compact Firewall</h3>
          <p>Full firewall functionality in a compact form factor. Designed for smaller sites, branch offices, and retail locations.</p>
          <ul style="margin-top:1rem;padding-left:1.2rem;font-size:0.92rem;color:var(--muted);">
            <li>Compact, space-efficient design</li>
            <li>Full stateful firewall + DNS security</li>
            <li>VPN and SD-WAN capable</li>
            <li>Perfect for branches and retail</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section>
    <div class="section-inner">
      <div style="text-align:center;max-width:640px;margin:0 auto 2rem;">
        <div class="section-label">Security Capabilities</div>
        <h2>Comprehensive <span class="grad">Network Security</span></h2>
        <p class="section-sub" style="margin:0.8rem auto 0;text-align:center;">Meter firewalls combine multiple security functions into one integrated appliance — replacing the patchwork of tools most businesses cobble together.</p>
      </div>
      <div class="products-grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));">
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon"><Icon name="lucide:shield" /></div>
          <h3>Stateful Firewall</h3>
          <p>Track and control all network connections with stateful inspection. Define granular rules for what traffic is allowed in and out.</p>
        </div>
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon"><Icon name="lucide:globe" /></div>
          <h3>DNS Filtering</h3>
          <p>Block access to malicious, phishing, and unwanted domains at the network level — protecting every device without installing agents.</p>
        </div>
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon"><Icon name="lucide:lock-keyhole" /></div>
          <h3>VPN Access</h3>
          <p>Secure remote access for employees working from anywhere. Site-to-site VPN connects branch offices over encrypted tunnels.</p>
        </div>
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon"><Icon name="lucide:traffic-cone" /></div>
          <h3>Traffic Shaping</h3>
          <p>Prioritize business-critical applications and limit bandwidth hogs. Ensure your most important traffic always gets through.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section>
    <div class="section-inner" style="text-align:center;padding:4rem 1.5rem;">
      <h2>Secure Your Network <span class="grad">the Simple Way</span></h2>
      <p class="section-sub" style="max-width:600px;margin:0.8rem auto 2rem;text-align:center;">Contact Blue Cap IT for a security assessment. We'll evaluate your current firewall setup and show you how Meter's integrated approach delivers better protection with less complexity.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="contact.html" class="btn-primary">Get a Free Quote</a>
        <a href="tel:4108584031" class="btn-ghost">Call (410) 858-4031</a>
      </div>
    </div>
  </section>
</MainLayout>
