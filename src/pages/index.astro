---
import MainLayout from '../layouts/MainLayout.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

// X / Twitter handle for Blue Cap IT.
const X_HANDLE = 'blue_cap_it';
const X_URL = `https://x.com/${X_HANDLE}`;
---
<MainLayout title="Blue Cap IT | Boutique Managed IT Partner" description="Blue Cap IT is your boutique IT partner — managed IT, network as a service, cybersecurity, physical security, and AI video intelligence delivered by people who answer the phone.">

  <!-- HERO ROTATOR + VALUE PROP -->
  <section class="hero" style="background:var(--white);padding:0;">
    <style>
      .hero::before, .hero::after, .hero .hero-bg { display: none !important; }
    </style>
    <div class="hero-rotator">
      <div class="rotator-stage">
        <a href="managed-services.html" class="rotator-slide active">
          <img src="/images/managed-services-hero.jpg" alt="Real-time monitoring dashboard with metrics" />
          <div class="rotator-content">
            <span class="rotator-label">Managed IT</span>
            <h2>Your complete outsourced IT department.</h2>
            <span class="rotator-cta">Learn more →</span>
          </div>
        </a>
        <a href="naas.html" class="rotator-slide">
          <img src="/images/naas-hero.jpg" alt="Fiber optic light radiating outward in vibrant blue" />
          <div class="rotator-content">
            <span class="rotator-label">Network as a Service</span>
            <h2>Your entire network. One monthly subscription.</h2>
            <span class="rotator-cta">Learn more →</span>
          </div>
        </a>
        <a href="cybersecurity.html" class="rotator-slide">
          <img src="/images/cybersecurity-hero.jpg" alt="Glowing blue laptop keyboard close-up" />
          <div class="rotator-content">
            <span class="rotator-label">Cybersecurity</span>
            <h2>All-in-one cybersecurity. Built for your business.</h2>
            <span class="rotator-cta">Learn more →</span>
          </div>
        </a>
        <a href="huntress.html" class="rotator-slide">
          <img src="/images/huntress-hero.jpg" alt="Security operations center with a wall of monitors" />
          <div class="rotator-content">
            <span class="rotator-label">Managed Security</span>
            <h2>24/7 SOC-backed protection. Threats stopped in minutes.</h2>
            <span class="rotator-cta">Learn more →</span>
          </div>
        </a>
        <a href="verkada.html" class="rotator-slide">
          <img src="/250228_Family_Portrait_Square0120_Levels-Edit.png" alt="Verkada physical security product family" />
          <div class="rotator-content">
            <span class="rotator-label">Physical Security</span>
            <h2>Cloud-managed cameras, access control, and sensors.</h2>
            <span class="rotator-cta">Learn more →</span>
          </div>
        </a>
        <a href="spotai.html" class="rotator-slide">
          <img src="/images/spotai-hero.jpg" alt="Two surveillance cameras mounted on a wall" />
          <div class="rotator-content">
            <span class="rotator-label">AI Video Intelligence</span>
            <h2>Turn your existing cameras into AI teammates.</h2>
            <span class="rotator-cta">Learn more →</span>
          </div>
        </a>
      </div>
      <div class="rotator-dots" role="tablist" aria-label="Service showcase">
        <button class="active" aria-label="Show Managed IT slide" type="button"></button>
        <button aria-label="Show Network as a Service slide" type="button"></button>
        <button aria-label="Show Cybersecurity slide" type="button"></button>
        <button aria-label="Show Managed Security slide" type="button"></button>
        <button aria-label="Show Physical Security slide" type="button"></button>
        <button aria-label="Show AI Video Intelligence slide" type="button"></button>
      </div>
    </div>

    <div class="hero-inner" style="grid-template-columns:1fr;padding:3rem 4% 4rem;">
      <div class="hero-content" style="max-width:800px;text-align:center;margin:0 auto;">
        <h1>Your Boutique <span class="grad">IT Partner.</span></h1>
        <p class="hero-sub" style="text-align:center;max-width:720px;margin:0 auto;color:var(--text-mid);">Blue Cap IT delivers enterprise-grade managed IT, network, security, and video intelligence — backed by the personal service of a trusted advisor. We measure success by your outcomes, not by what we sold you last quarter.</p>
        <div class="hero-btns" style="justify-content:center;">
          <a href="contact.html" class="btn-primary">Free Consultation</a>
          <a href="services.html" class="btn-ghost">Explore Services</a>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST PILLARS -->
  <section style="background:var(--surface);">
    <div class="section-inner">
      <div style="text-align:center;max-width:680px;margin:0 auto 2rem;">
        <div class="section-label">Why Blue Cap IT</div>
        <h2>Built Around <span class="grad">Trust.</span></h2>
        <p class="section-sub" style="margin:0.8rem auto 0;text-align:center;">We're small enough to know your business and big enough to handle your entire IT stack. Every engagement starts with listening — and ends with outcomes.</p>
      </div>
      <div class="trust-pillars">
        <div class="trust-pillar">
          <div class="trust-pillar-icon"><Icon name="lucide:gem" /></div>
          <h3>Boutique Partner</h3>
          <p>Small enough to know you personally. Big enough to handle every layer of your technology under one accountable roof.</p>
        </div>
        <div class="trust-pillar">
          <div class="trust-pillar-icon"><Icon name="lucide:heart-handshake" /></div>
          <h3>Customer Service First</h3>
          <p>Real people, fast response, no ticket queue across time zones. When you call, you reach someone who knows your systems.</p>
        </div>
        <div class="trust-pillar">
          <div class="trust-pillar-icon"><Icon name="lucide:graduation-cap" /></div>
          <h3>Consulting Over Sales</h3>
          <p>We'd rather teach you than sell to you. Free assessments, transparent pricing, and roadmaps you can actually understand.</p>
        </div>
        <div class="trust-pillar">
          <div class="trust-pillar-icon"><Icon name="lucide:target" /></div>
          <h3>Outcomes-Focused</h3>
          <p>We measure success by your uptime, productivity, and peace of mind — not by activity reports or upsell quotas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK -->
  <section>
    <div class="section-inner">
      <div style="text-align:center;max-width:680px;margin:0 auto 0.5rem;">
        <div class="section-label">How We Work</div>
        <h2>Listen. Recommend. <span class="grad">Deliver.</span></h2>
        <p class="section-sub" style="margin:0.8rem auto 0;text-align:center;">A consultative process that starts with understanding your business — not pushing a product catalog.</p>
      </div>
      <div class="how-we-work">
        <div class="how-step">
          <div class="how-step-num">1</div>
          <div class="how-step-icon"><Icon name="lucide:headphones" /></div>
          <h3>Listen</h3>
          <p>Free consultation, walking your facility, learning your business. We ask questions before we make any recommendation.</p>
        </div>
        <div class="how-step">
          <div class="how-step-num">2</div>
          <div class="how-step-icon"><Icon name="lucide:pencil-ruler" /></div>
          <h3>Recommend</h3>
          <p>Custom plan with transparent pricing — even if it means recommending less. Roadmaps you can read, no jargon.</p>
        </div>
        <div class="how-step">
          <div class="how-step-num">3</div>
          <div class="how-step-icon"><Icon name="lucide:rocket" /></div>
          <h3>Deliver</h3>
          <p>End-to-end implementation, training, and ongoing support. Long-term partnership, not a one-off transaction.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES GRID -->
  <section style="background:var(--off-white);">
    <div class="section-inner">
      <div style="text-align:center;max-width:680px;margin:0 auto 2rem;">
        <div class="section-label">What We Deliver</div>
        <h2>Full-Stack IT.<br/><span class="grad">Backed by Industry Leaders.</span></h2>
        <p class="section-sub" style="margin:0.8rem auto 0;text-align:center;">Six service areas, one accountable partner. Click any service to learn more.</p>
      </div>
      <div class="products-grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));max-width:1100px;margin:0 auto;">
        <a href="managed-services.html" class="product-card" style="text-decoration:none;color:inherit;border-top:3px solid var(--elec);">
          <div class="pcard-icon"><Icon name="lucide:monitor" /></div>
          <h3>Managed IT</h3>
          <p>Helpdesk, monitoring, patching, backup, Microsoft 365, network, and vCIO services.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="naas.html" class="product-card" style="text-decoration:none;color:inherit;border-top:3px solid #4a1d96;">
          <div class="pcard-icon"><Icon name="lucide:globe" /></div>
          <h3>Network as a Service</h3>
          <p>Your entire network as one monthly subscription. Switches, Wi-Fi 7, firewalls, 5G, install, 24/7 ops.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="cybersecurity.html" class="product-card" style="text-decoration:none;color:inherit;border-top:3px solid #6366f1;">
          <div class="pcard-icon"><Icon name="lucide:shield" /></div>
          <h3>Cybersecurity</h3>
          <p>All-in-one Coro platform — endpoint, email, cloud, network, data governance, training.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="huntress.html" class="product-card" style="text-decoration:none;color:inherit;border-top:3px solid #00b4a0;">
          <div class="pcard-icon"><Icon name="lucide:target" /></div>
          <h3>Managed Security</h3>
          <p>24/7 Huntress SOC — managed EDR, identity threat detection, SIEM, awareness training.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="verkada.html" class="product-card" style="text-decoration:none;color:inherit;border-top:3px solid #0a2540;">
          <div class="pcard-icon"><Icon name="lucide:camera" /></div>
          <h3>Physical Security</h3>
          <p>Verkada cameras, access control, sensors, alarms, and intercoms — all cloud-managed.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="spotai.html" class="product-card" style="text-decoration:none;color:inherit;border-top:3px solid #1a1a2e;">
          <div class="pcard-icon"><Icon name="lucide:video" /></div>
          <h3>AI Video Intelligence</h3>
          <p>spot.ai turns existing cameras into AI teammates with deep-learning analytics and alerts.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- LATEST FROM BLOG + X CALLOUT -->
  <section>
    <div class="section-inner">
      <div style="text-align:center;max-width:680px;margin:0 auto 2rem;">
        <div class="section-label">Stay Current</div>
        <h2>Insights &amp; <span class="grad">Updates.</span></h2>
        <p class="section-sub" style="margin:0.8rem auto 0;text-align:center;">Latest from the Blue Cap IT blog — and our feed on X.</p>
      </div>
      <div class="feed-row">
        <div class="blog-stack">
          {latestPosts.map((post) => (
            <a href={`blog/${post.id}.html`} class="home-blog-card">
              <div class="home-blog-meta">{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })} · {post.data.author}</div>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <span class="pcard-arrow">Read more →</span>
            </a>
          ))}
        </div>
        <a href={X_URL} target="_blank" rel="noopener noreferrer" class="x-callout">
          <div class="x-callout-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </div>
          <h3>Follow Blue Cap IT on X</h3>
          <p>Real-time security alerts, partner updates, and tech insights from the Blue Cap IT team.</p>
          <span class="x-callout-handle">@{X_HANDLE}</span>
        </a>
      </div>
      <div style="text-align:center;margin-top:2.5rem;">
        <a href="blog.html" class="btn-ghost">All News &amp; Posts</a>
      </div>
    </div>
  </section>

  <!-- PARTNER RIBBON -->
  <section style="background:var(--surface);padding:3rem 0 3.5rem;">
    <div style="text-align:center;max-width:680px;margin:0 auto 1.5rem;padding:0 1.5rem;">
      <div class="section-label">Trusted Partnerships</div>
      <h2>Industry Leaders, <span class="grad">Local Service.</span></h2>
    </div>
    <div class="partner-ribbon">
      <a href="verkada.html"><img src="/images/verkada-partner.png" alt="Verkada Authorized Reseller"/></a>
      <a href="cybersecurity.html"><img src="/Coro/coro-logo-wide-indigo.png" alt="Coro Partner"/></a>
      <a href="huntress.html"><img src="/Huntress/huntress-logo-teal.png" alt="Huntress Partner"/></a>
      <a href="spotai.html"><img src="/spotai/spotai-logo.png" alt="spot.ai Partner"/></a>
      <a href="meter.html"><img src="/meter/Meter-purple.png" alt="Meter Partner"/></a>
    </div>
  </section>

  <!-- FINAL CTA -->
  <div class="cta-band">
    <div class="section-label">Ready to Get Started?</div>
    <h2>Talk to a Real Person.<br/><span class="grad">Free Consultation.</span></h2>
    <p>No pressure, no jargon, no upsell. Tell us what you're trying to accomplish — we'll listen first, recommend second.</p>
    <div class="btn-group">
      <a href="contact.html" class="btn-primary">Request a Free Quote</a>
      <a href="tel:4108584031" class="btn-ghost"><Icon name="lucide:phone" /> Call (410) 858-4031</a>
      <a href="mailto:info@bluecapit.com" class="btn-ghost"><Icon name="lucide:mail" /> info@bluecapit.com</a>
    </div>
  </div>

  <!-- ROTATOR JS -->
  <script is:inline>
    (function() {
      const slides = document.querySelectorAll('.rotator-slide');
      const dots = document.querySelectorAll('.rotator-dots button');
      const stage = document.querySelector('.hero-rotator');
      if (!slides.length || !stage) return;

      let current = 0;
      let intervalId = null;
      const ROTATE_MS = 4000;

      function show(i) {
        slides.forEach((s, idx) => s.classList.toggle('active', idx === i));
        dots.forEach((d, idx) => d.classList.toggle('active', idx === i));
        current = i;
      }
      function next() { show((current + 1) % slides.length); }
      function start() {
        if (intervalId) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        intervalId = setInterval(next, ROTATE_MS);
      }
      function stop() {
        if (intervalId) { clearInterval(intervalId); intervalId = null; }
      }
      dots.forEach(function(d, idx) {
        d.addEventListener('click', function() { stop(); show(idx); start(); });
      });
      stage.addEventListener('mouseenter', stop);
      stage.addEventListener('mouseleave', start);
      document.addEventListener('visibilitychange', function() {
        if (document.hidden) stop(); else start();
      });
      start();
    })();
  </script>

</MainLayout>
