---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Blue Cap IT | Managed IT, Cybersecurity & Verkada Security Solutions" description="Blue Cap IT is a managed service provider, Coro cybersecurity partner, and official Verkada Gold Partner. We deliver IT management, cybersecurity, and physical security solutions for businesses.">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="grid-overlay"></div>
    <div class="hero-inner" style="grid-template-columns:1fr;">
      <div class="hero-content" style="max-width:740px;">
        <div class="hero-badges">
          <span class="badge-pill badge-partner">Managed Service Provider</span>
          <span class="badge-pill" style="background:rgba(255,255,255,0.05);border:1px solid var(--border);color:var(--text-muted);">Verkada Gold Partner</span>
          <span class="badge-pill" style="background:rgba(255,255,255,0.05);border:1px solid var(--border);color:var(--text-muted);">Coro Partner</span>
        </div>
        <h1>IT Services &amp; Security,<br/><span class="grad">Simply Delivered.</span></h1>
        <p class="hero-sub">Blue Cap IT is your complete technology partner — managed IT services, cybersecurity powered by Coro, and physical security through Verkada. From helpdesk support to enterprise security deployments, we handle everything.</p>
        <div class="hero-btns">
          <a href="managed-services.html" class="btn-primary">Managed IT Services</a>
          <a href="cybersecurity.html" class="btn-primary" style="background:var(--navy);">Cybersecurity</a>
          <a href="contact.html" class="btn-ghost">Get a Free Quote</a>
        </div>
        <div class="hero-stats">
          <div><div class="stat-num">24/7</div><div class="stat-label">Monitoring &amp; Support</div></div>
          <div><div class="stat-num">MSP</div><div class="stat-label">Managed Services</div></div>
          <div><div class="stat-num">Gold</div><div class="stat-label">Verkada Partner</div></div>
        </div>
      </div>
    </div>
    <!-- Hero product image -->
    <div style="position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:0 4%;">
      <img src="/logo.svg" alt="Blue Cap IT" class="img-hero-band"/>
    </div>
  </section>

  <!-- GOLD PARTNER BAND -->
  
      <a href="contact.html" class="btn-primary btn-sm" style="margin-left:auto;">Get Partner Pricing →</a>
    </div>
  </div>

  <!-- MANAGED IT & CYBERSECURITY -->
  <section style="background:var(--surface);">
    <div class="section-inner">
      <div style="text-align:center;max-width:640px;margin:0 auto 1rem;">
        <div class="section-label">IT Services &amp; Cybersecurity</div>
        <h2>More Than Security Hardware.<br/><span class="grad">A Complete IT Partner.</span></h2>
        <p class="section-sub" style="margin:0.8rem auto 0;text-align:center;">Blue Cap IT goes beyond physical security. We provide managed IT services and enterprise-grade cybersecurity to keep your business running and protected.</p>
      </div>
      <div class="products-grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr));max-width:900px;margin:0 auto;">
        <a href="managed-services.html" class="product-card">
          <div class="pcard-tag">Managed Services</div>
          <div class="pcard-icon">🖥️</div>
          <h3>Managed IT Services</h3>
          <p>Your complete outsourced IT department. Remote monitoring, helpdesk support, patch management, backup &amp; disaster recovery, Microsoft 365 management, network management, and vCIO services.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="cybersecurity.html" class="product-card">
          <div class="pcard-tag">Coro Partner</div>
          <div class="pcard-icon">🛡️</div>
          <h3>Coro Cybersecurity</h3>
          <p>All-in-one cybersecurity platform built for small and mid-sized businesses. Endpoint protection, email security, cloud app security, network protection, data governance, and security awareness training.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- VERKADA PRODUCT LINEUP -->
  <section id="products">
    <div class="section-inner">
      <div style="text-align:center;max-width:640px;margin:0 auto 1rem;">
        <div class="section-label">Complete Verkada Product Suite</div>
        <h2>Everything You Need,<br/><span class="grad">One Trusted Partner.</span></h2>
        <p class="section-sub" style="margin:0.8rem auto 0;text-align:center;">As a Verkada Gold Partner, Blue Cap IT provides access to every product in the Verkada portfolio — fully installed and supported.</p>
      </div>
      <!-- Cameras family image -->
      <img src="/logo.svg" alt="Blue Cap IT" class="img-hero-band" style="margin-bottom:1rem;"/>
      <div class="products-grid">
        <a href="cameras.html" class="product-card">
          <div class="pcard-tag">Verkada Solution</div>
          <div class="pcard-icon">📷</div>
          <h3>Video Security Cameras</h3>
          <p>AI-powered cameras with built-in storage, cloud management, and advanced analytics — person detection, license plate recognition, facial recognition, and more.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="access-control.html" class="product-card">
          <div class="pcard-tag">Verkada Solution</div>
          <div class="pcard-icon">🔑</div>
          <h3>Access Control</h3>
          <p>Cloud-managed door controllers, smart card readers, and mobile credentials. Grant, revoke, and audit access from anywhere in real time.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="sensors.html" class="product-card">
          <div class="pcard-tag">Verkada Solution</div>
          <div class="pcard-icon">🌡️</div>
          <h3>Environmental Sensors</h3>
          <p>Monitor temperature, humidity, air quality, motion, water leaks, and more. Instant alerts and 90-day historical trends in your dashboard.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="alarms.html" class="product-card">
          <div class="pcard-tag">Verkada Solution</div>
          <div class="pcard-icon">🚨</div>
          <h3>Alarms &amp; Intrusion</h3>
          <p>Integrated alarm systems that tie directly into your cameras and access control — no isolated alarm panels. One platform, complete coverage.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="intercom.html" class="product-card">
          <div class="pcard-tag">Verkada Solution</div>
          <div class="pcard-icon">📡</div>
          <h3>Intercom &amp; Visitor Management</h3>
          <p>Video intercoms with remote unlock, two-way audio, and digital visitor check-in. Hosts get notified instantly via the Verkada mobile app.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="command.html" class="product-card">
          <div class="pcard-tag">Verkada Platform</div>
          <div class="pcard-icon">☁️</div>
          <h3>Verkada Command Platform</h3>
          <p>The unified cloud software tying every Verkada device together. No VPNs, no on-site servers, no complex IT — just a browser and a login.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- WHY BLUE CAP IT -->
  <section>
    <div class="section-inner">
      <div class="why-grid">
        <div>
          <div class="section-label">Why Blue Cap IT</div>
          <h2>Local Expertise.<br/><span class="grad">Enterprise Results.</span></h2>
          <p class="section-sub">We're not just a vendor — we're a full-service managed IT provider, Coro cybersecurity partner, and Verkada Gold Partner who guides you from strategy through implementation and long-term support.</p>
          <div class="verkada-gold-section">
            <img src="/verkada-gold-partner-badge.png" alt="Verkada Gold Partner" style="height:48px;width:auto;flex-shrink:0;"/>
            <p><strong>Verkada Gold Partner status</strong> means you get factory-direct pricing, full product access, manufacturer warranties, and co-support from both Blue Cap IT and Verkada's own engineering team.</p>
          </div>
          <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
            <a href="contact.html" class="btn-primary">Get Started Today</a>
            <a href="about.html" class="btn-ghost">About Us</a>
          </div>
        </div>
        <ul class="why-list">
          <li class="why-item">
            <div class="why-icon">★</div>
            <div><h4>Verkada Gold Partner</h4><p>Genuine products, manufacturer warranties, and factory-direct licensing — at competitive pricing direct from an authorized Gold-level Verkada reseller.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon">🔧</div>
            <div><h4>End-to-End Installation</h4><p>We handle physical mounting, network configuration, cloud onboarding, and staff training — your team is productive from day one.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon">📋</div>
            <div><h4>Ongoing License Management</h4><p>We track renewals, handle Verkada subscription management, and notify you before anything expires. Never worry about lapsing coverage.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon">⚡</div>
            <div><h4>Fast, Responsive Support</h4><p>Security issues can't wait. Call us at (410) 858-4031 or email <a href="mailto:info@bluecapit.com" style="color:var(--blue);">info@bluecapit.com</a> for fast, dedicated support.</p></div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FULL PLATFORM IMAGE -->
  <section style="padding:2rem 4% 5rem;background:var(--off-white);">
    <div class="section-inner" style="text-align:center;">
      <div class="section-label">The Complete Platform</div>
      <h2 style="margin-bottom:0.5rem;">One System. <span class="grad">Total Visibility.</span></h2>
      <p class="section-sub" style="margin:0 auto 2rem;">Verkada unifies cameras, access control, sensors, alarms, intercom, and wireless networking into a single cloud-managed platform.</p>
      <img src="/logo.svg" alt="Blue Cap IT" class="img-hero-band"/>
    </div>
  </section>

  <!-- CTA BAND -->
  <div class="cta-band">
    <div class="section-label">Ready to Get Started?</div>
    <h2>Build Your IT Strategy<br/><span class="grad">with Blue Cap IT</span></h2>
    <p>Whether you need managed IT services, cybersecurity, or physical security — we'll design the right solution for your needs and budget, with zero pressure.</p>
    <div class="btn-group">
      <a href="contact.html" class="btn-primary">Request a Free Quote</a>
      <a href="tel:4108584031" class="btn-ghost">📞 Call (410) 858-4031</a>
      <a href="mailto:info@bluecapit.com" class="btn-ghost">✉️ info@bluecapit.com</a>
    </div>
  </div>

</MainLayout>
