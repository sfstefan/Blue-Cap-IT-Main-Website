        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon">🧠</div>
          <h3>Virtual CIO</h3>
          <p>Strategic IT planning, budgeting, and roadmaps — executive-level guidance without the executive-level salary.</p>
        </div>
      </div>
      <div style="text-align:center;margin-top:2rem;">
        <a href="managed-services.html" class="btn-primary">Explore Managed IT Services</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ -->
