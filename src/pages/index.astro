---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Blue Cap IT | Managed IT, Cybersecurity, Verkada & Meter Networking" description="Blue Cap IT is a managed service provider, Verkada Gold Partner, Coro Partner, Huntress Partner, and Meter Partner. We deliver managed IT, cybersecurity, physical security, managed detection and response, and enterprise networking.">

  <!-- HERO -->
  <section class="hero" style="background:var(--white);">
    <style>
      .hero::before, .hero::after, .hero .hero-bg { display: none !important; }
      .partner-section-header { display:flex; align-items:center; justify-content:center; gap:1rem; margin-bottom:0.5rem; flex-wrap:wrap; }
      .partner-section-header img { height:40px; width:auto; }
      .partner-divider { border:none; height:3px; border-radius:2px; margin:0; }
    </style>
    <!-- Hero banner image -->
    <div style="position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:0 4%;">
      <img src="/images/BLUECAPTwitter.jpg" alt="Blue Cap IT — Managed IT, Cybersecurity, Physical Security, and Networking" width="1200" height="675" style="width:100%;height:auto;border-radius:1rem;box-shadow:0 8px 32px rgba(0,0,0,0.25);"/>
    </div>
    <div class="hero-inner" style="grid-template-columns:1fr;">
      <div class="hero-content" style="max-width:800px;text-align:center;margin:0 auto;">
        <div class="hero-badges" style="justify-content:center;">
          <a href="managed-services.html" class="badge-pill" style="background:rgba(30,111,230,0.08);border:1px solid rgba(30,111,230,0.2);color:var(--navy);text-decoration:none;">Managed IT</a>
          <a href="verkada.html" class="badge-pill" style="background:rgba(30,111,230,0.08);border:1px solid rgba(30,111,230,0.2);color:var(--navy);text-decoration:none;">Verkada Gold Partner</a>
          <a href="cybersecurity.html" class="badge-pill" style="background:rgba(30,111,230,0.08);border:1px solid rgba(30,111,230,0.2);color:var(--navy);text-decoration:none;">Coro Partner</a>
          <a href="huntress.html" class="badge-pill" style="background:rgba(30,111,230,0.08);border:1px solid rgba(30,111,230,0.2);color:var(--navy);text-decoration:none;">Huntress Partner</a>
          <a href="spotai.html" class="badge-pill" style="background:rgba(30,111,230,0.08);border:1px solid rgba(30,111,230,0.2);color:var(--navy);text-decoration:none;">spot.ai Partner</a>
          <a href="meter.html" class="badge-pill" style="background:rgba(30,111,230,0.08);border:1px solid rgba(30,111,230,0.2);color:var(--navy);text-decoration:none;">Meter Partner</a>
        </div>
        <h1>Your Boutique <span class="grad">IT Partner.</span></h1>
        <p class="hero-sub" style="text-align:center;max-width:700px;margin:0 auto;color:var(--text-mid);">Blue Cap IT is a full-service Managed Service Provider, official Verkada Gold Partner, Coro cybersecurity partner, Huntress managed security partner, and Meter networking partner. We deliver managed IT, enterprise-grade cybersecurity, physical security, and network infrastructure solutions — all backed by the kind of personal, responsive customer support that big providers simply can't match. When you call Blue Cap IT, you get a real person who knows your business, your systems, and your goals.</p>
        <div class="hero-btns" style="justify-content:center;">
          <a href="managed-services.html" class="btn-primary">Managed IT</a>
          <a href="cybersecurity.html" class="btn-primary" style="background:var(--navy);">Coro</a>
          <a href="verkada.html" class="btn-primary" style="background:#0a2540;">Verkada</a>
          <a href="huntress.html" class="btn-primary" style="background:#00b4a0;">Huntress</a>
          <a href="spotai.html" class="btn-primary" style="background:#1a1a2e;">spot.ai</a>
          <a href="meter.html" class="btn-primary" style="background:#4a1d96;">Meter</a>
          <a href="contact.html" class="btn-ghost">Get a Free Quote</a>
        </div>
      </div>
    </div>
  </section>

  <!-- OUR SOLUTIONS — 4 cards overview -->
  <section style="background:var(--surface);">
    <div class="section-inner">
      <div style="text-align:center;max-width:700px;margin:0 auto 1.5rem;">
        <div class="section-label">Our Solutions</div>
        <h2>Four Pillars.<br/><span class="grad">One IT Partner.</span></h2>
        <p class="section-sub" style="margin:0.8rem auto 0;text-align:center;">Blue Cap IT brings together managed IT, cybersecurity, physical security, and enterprise networking — so you get one partner for everything.</p>
      </div>
      <div class="products-grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));max-width:1000px;margin:0 auto;">
        <a href="managed-services.html" class="product-card" style="text-decoration:none;color:inherit;border-top:3px solid var(--elec);">
          <div class="pcard-icon">🖥️</div>
          <h3>Managed IT</h3>
          <p>Your complete outsourced IT department. Helpdesk, monitoring, patching, backup, Microsoft 365, and vCIO services.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="cybersecurity.html" class="product-card" style="text-decoration:none;color:inherit;border-top:3px solid #6366f1;">
          <div class="pcard-icon">🛡️</div>
          <h3>Coro Cybersecurity</h3>
          <p>All-in-one cybersecurity for SMBs. Endpoint, email, cloud, network, data governance, and security training.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="verkada.html" class="product-card" style="text-decoration:none;color:inherit;border-top:3px solid #0a2540;">
          <div class="pcard-icon">📷</div>
          <h3>Verkada Security</h3>
          <p>Cloud-managed cameras, access control, sensors, alarms, intercoms, and more — all in one platform.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="huntress.html" class="product-card" style="text-decoration:none;color:inherit;border-top:3px solid #00b4a0;">
          <div class="pcard-icon">🎯</div>
          <h3>Huntress Security</h3>
          <p>24/7 SOC-backed EDR, identity threat detection, SIEM, and security awareness training.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="spotai.html" class="product-card" style="text-decoration:none;color:inherit;border-top:3px solid #1a1a2e;">
          <div class="pcard-icon">📹</div>
          <h3>spot.ai Video Intelligence</h3>
          <p>AI-powered video analytics, intelligent recording, and real-time alerts from your existing cameras.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="meter.html" class="product-card" style="text-decoration:none;color:inherit;border-top:3px solid #4a1d96;">
          <div class="pcard-icon">🌐</div>
          <h3>Meter Networking</h3>
          <p>Full-stack enterprise networking as a service. Switches, Wi-Fi 7, firewalls, and 5G — zero upfront costs.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- MANAGED IT SECTION -->
  <!-- ═══════════════════════════════════════ -->
  <section>
    <div class="section-inner">
      <hr class="partner-divider" style="background:var(--elec);"/>
      <div style="text-align:center;max-width:640px;margin:1.5rem auto 1rem;">
        <div class="section-label">Managed IT Services</div>
        <h2>Your Complete <span class="grad">IT Department.</span></h2>
        <p class="section-sub" style="margin:0.8rem auto 0;text-align:center;">Stop juggling multiple IT vendors. Blue Cap IT provides full-service managed IT — from helpdesk support to strategic planning — so your team can focus on growing the business.</p>
      </div>
      <div class="products-grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));max-width:900px;margin:0 auto;">
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon">📡</div>
          <h3>Remote Monitoring</h3>
          <p>24/7 monitoring of your servers, workstations, and network devices with proactive alerts.</p>
        </div>
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon">🎧</div>
          <h3>Helpdesk Support</h3>
          <p>Fast, friendly IT support from real people who know your systems and your business.</p>
        </div>
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon">💾</div>
