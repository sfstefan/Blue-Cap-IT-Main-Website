---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Verkada Alarms &amp; Intrusion Detection | Blue Cap IT — Gold Partner">
  <div class="inner-hero">
    <div class="section-inner">
      <div class="crumbs"><a href="index.html">Home</a> <span>/</span> <a href="verkada.html">Verkada Solutions</a> <span>/</span> Alarms &amp; Intrusion</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;">
        <div>
          <div class="section-label">Verkada Solution</div>
          <h1>Alarms &amp; <span class="grad">Intrusion Detection</span></h1>
          <p class="section-sub">A fully integrated alarm system tied directly into your cameras and access control — no isolated panels, no separate monitoring contracts.</p>
          <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
            <a href="contact.html" class="btn-primary">Get an Alarm System Quote</a>
            <a href="tel:4108584031" class="btn-ghost btn-sm">📞 (410) 858-4031</a>
          </div>
        </div>
        <img src="data:image/png;base64," alt="Verkada Alarm System Family" class="feature-img"/>
      </div>
    </div>
  </div>

  <section>
    <div class="section-inner">
      <div class="feature-list">
        <div class="feature-row">
          <div class="feature-visual"><div class="feature-visual-bg"></div><div class="big-icon">🔗</div></div>
          <div class="feature-content">
            <h3>Fully Integrated with Cameras &amp; Access</h3>
            <p>Verkada alarms are natively integrated with your camera and access control system. When an alarm triggers, you instantly see live video from the nearest camera — no switching between apps.</p>
            <ul class="feature-bullets">
              <li>Auto-linked camera feed on every alarm event</li>
              <li>Arm/disarm via access credentials or app</li>
              <li>One dashboard for all security functions</li>
              <li>No third-party monitoring service required</li>
              <li>Integrates with professional monitoring if desired</li>
            </ul>
          </div>
        </div>
        <div class="feature-row rev">
          <div class="feature-visual"><div class="feature-visual-bg"></div><div class="big-icon">📱</div></div>
          <div class="feature-content">
            <h3>Instant Mobile Alerts</h3>
            <p>When an intrusion is detected, Verkada notifies the right people immediately — with video evidence attached. Respond with context, not just noise.</p>
            <ul class="feature-bullets">
              <li>Push notifications with live video thumbnail</li>
              <li>Configurable alert recipient lists</li>
              <li>Remote arm/disarm from mobile app</li>
              <li>Audio siren and strobe light control</li>
              <li>False alarm reduction via AI video verification</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="section-label">Secure Your Perimeter</div>
    <h2>Integrated Alarms, Installed by<br/><span class="grad">Blue Cap IT</span></h2>
    <p>We design, install, and configure Verkada alarm systems that work seamlessly with your existing cameras and access control.</p>
    <div class="btn-group">
      <a href="contact.html" class="btn-primary">Request a Free Alarm Assessment</a>
      <a href="tel:4108584031" class="btn-ghost">📞 (410) 858-4031</a>
      <a href="mailto:info@bluecapit.com" class="btn-ghost">✉️ info@bluecapit.com</a>
    </div>
  </div>
</MainLayout>
