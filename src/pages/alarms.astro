---
import MainLayout from '../layouts/MainLayout.astro';
import { Icon } from 'astro-icon/components';
---
<MainLayout title="Verkada Alarms &amp; Intrusion Detection | Blue Cap IT — Gold Partner" description="Verkada alarm systems integrate directly with cameras and access control — no isolated panels. Wireless sensors, professional monitoring, and cloud management through Blue Cap IT.">
  <div class="inner-hero">
    <div class="section-inner">
      <div class="crumbs"><a href="index.html">Home</a> <span>/</span> <a href="verkada.html">Verkada Solutions</a> <span>/</span> Alarms &amp; Intrusion</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;">
        <div>
          <div class="section-label">Verkada Solution</div>
          <h1>Alarms &amp; <span class="grad">Intrusion Detection</span></h1>
          <p class="section-sub">A fully integrated alarm system tied directly into your cameras and access control — no isolated panels, no separate monitoring contracts.</p>
          <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
            <a href="contact.html" class="btn-primary">Get an Alarm System Quote</a>
            <a href="tel:4108584031" class="btn-ghost btn-sm">📞 (410) 858-4031</a>
          </div>
        </div>
        <img src="/250916_Alarms_Family_right_Side_2_0030.png" alt="Verkada Alarm System" class="feature-img"/>
      </div>
    </div>
  </div>

  <section>
    <div class="section-inner">
      <div class="feature-list">
        <div class="feature-row">
          <div class="feature-visual"><div class="feature-visual-bg"></div><div class="big-icon"><Icon name="lucide:link" /></div></div>
          <div class="feature-content">
            <h3>Fully Integrated with Cameras &amp; Access</h3>
            <p>Verkada alarms are natively integrated with your camera and access control system. When an alarm triggers, you instantly see live video from the nearest camera — no switching between apps.</p>
            <ul class="feature-bullets">
              <li>Auto-linked camera feed on every alarm event</li>
              <li>Arm/disarm via access credentials or app</li>
              <li>One dashboard for all security functions</li>
              <li>No third-party monitoring service required</li>
              <li>Integrates with professional monitoring if desired</li>
            </ul>
          </div>
        </div>
        <div class="feature-row rev">
          <div class="feature-visual"><div class="feature-visual-bg"></div><div class="big-icon"><Icon name="lucide:smartphone" /></div></div>
          <div class="feature-content">
            <h3>Instant Mobile Alerts</h3>
            <p>When an intrusion is detected, Verkada notifies the right people immediately — with video evidence attached. Respond with context, not just noise.</p>
            <ul class="feature-bullets">
              <li>Push notifications with live video thumbnail</li>
              <li>Configurable alert recipient lists</li>
              <li>Remote arm/disarm from mobile app</li>
              <li>Audio siren and strobe light control</li>
              <li>False alarm reduction via AI video verification</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>


  <section class="specs-section">
    <div class="section-label">Hardware</div>
    <h2>Alarm System <span class="grad">Hardware</span></h2>
    <div class="specs-grid">
      <div class="spec-card">
        <img src="/verkada/alarms/alarm-panel.png" alt="Verkada Alarm Panel BP52" style="width:100%;border-radius:0.5rem;margin-bottom:0.75rem;" />
        <h4>Alarm Panel (BP52)</h4>
        <p>Central hub that connects all sensors, communicates with the cloud, and triggers responses in real time.</p>
      </div>
      <div class="spec-card">
        <img src="/verkada/alarms/keypad.png" alt="Verkada Alarm Keypad" style="width:100%;border-radius:0.5rem;margin-bottom:0.75rem;" />
        <h4>Alarm Keypad</h4>
        <p>Touchscreen keypad for arming, disarming, and managing your alarm system on-site.</p>
      </div>
      <div class="spec-card">
        <img src="/verkada/alarms/hub.png" alt="Verkada Wireless Hub WH52" style="width:100%;border-radius:0.5rem;margin-bottom:0.75rem;" />
        <h4>Wireless Hub (WH52)</h4>
        <p>Extends wireless range to connect sensors across large facilities without additional wiring.</p>
      </div>
      <div class="spec-card">
        <img src="/verkada/alarms/pir-sensor.png" alt="Verkada PIR Motion Sensor BR32" style="width:100%;border-radius:0.5rem;margin-bottom:0.75rem;" />
        <h4>PIR Motion Sensor (BR32)</h4>
        <p>Detects movement using passive infrared technology, ideal for monitoring rooms and hallways.</p>
      </div>
      <div class="spec-card">
        <img src="/verkada/alarms/glass-break.png" alt="Verkada Glass Break Sensor BR34" style="width:100%;border-radius:0.5rem;margin-bottom:0.75rem;" />
        <h4>Glass Break Sensor (BR34)</h4>
        <p>Listens for the sound of breaking glass to detect forced entry through windows and glass doors.</p>
      </div>
      <div class="spec-card">
        <img src="/verkada/alarms/panic-button.png" alt="Verkada Panic Button BR33" style="width:100%;border-radius:0.5rem;margin-bottom:0.75rem;" />
        <h4>Panic Button (BR33)</h4>
        <p>One-press silent or audible alert for emergencies, instantly notifying your security team.</p>
      </div>
      <div class="spec-card">
        <img src="/verkada/alarms/siren.png" alt="Verkada Indoor Siren BZ11" style="width:100%;border-radius:0.5rem;margin-bottom:0.75rem;" />
        <h4>Indoor Siren (BZ11)</h4>
        <p>Loud audible alarm for indoor spaces, deterring intruders and alerting building occupants.</p>
      </div>
      <div class="spec-card">
        <img src="/verkada/alarms/outdoor-siren.png" alt="Verkada Outdoor Siren BZ32" style="width:100%;border-radius:0.5rem;margin-bottom:0.75rem;" />
        <h4>Outdoor Siren (BZ32)</h4>
        <p>Weather-resistant siren for exterior mounting, providing high-decibel alerts across your property.</p>
      </div>
      <div class="spec-card">
        <img src="/verkada/alarms/water-leak.png" alt="Verkada Water Leak Sensor BR35" style="width:100%;border-radius:0.5rem;margin-bottom:0.75rem;" />
        <h4>Water Leak Sensor (BR35)</h4>
        <p>Detects water leaks early to prevent costly damage in server rooms, basements, and utility areas.</p>
      </div>
      <div class="spec-card">
        <img src="/verkada/alarms/cellular-backup.png" alt="Verkada Cellular Backup Communicator" style="width:100%;border-radius:0.5rem;margin-bottom:0.75rem;" />
        <h4>Cellular Backup Communicator</h4>
        <p>Maintains alarm connectivity over cellular when your primary network goes down, ensuring uninterrupted protection.</p>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="section-label">Secure Your Perimeter</div>
    <h2>Integrated Alarms, Installed by<br/><span class="grad">Blue Cap IT</span></h2>
    <p>We design, install, and configure Verkada alarm systems that work seamlessly with your existing cameras and access control.</p>
    <div class="btn-group">
      <a href="contact.html" class="btn-primary">Request a Free Alarm Assessment</a>
      <a href="tel:4108584031" class="btn-ghost">📞 (410) 858-4031</a>
      <a href="mailto:info@bluecapit.com" class="btn-ghost">✉️ info@bluecapit.com</a>
    </div>
  </div>
</MainLayout>
