---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Services | Blue Cap IT — Managed IT, Cybersecurity & Security Solutions">
  <div class="inner-hero">
    <div class="section-inner">
      <div class="crumbs"><a href="index.html">Home</a> <span>/</span> Services</div>
      <div class="section-label">What We Do</div>
      <h1>Full-Stack IT <span class="grad">Services</span></h1>
      <p class="section-sub">Blue Cap IT delivers end-to-end technology services — managed IT, cybersecurity, and physical security. We're your single point of contact for everything technology.</p>
    </div>
  </div>

  <!-- MANAGED IT SERVICES -->
  <section>
    <div class="section-inner">
      <div style="text-align:center;max-width:640px;margin:0 auto 2rem;">
        <div class="section-label">Managed IT Services</div>
        <h2>Your Outsourced <span class="grad">IT Department</span></h2>
      </div>
      <div class="products-grid">
        <a href="managed-services.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">📡</div>
          <h3>Remote Monitoring &amp; Management</h3>
          <p>24/7 monitoring of your servers, workstations, and network devices. We detect and resolve issues proactively.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="managed-services.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">🎧</div>
          <h3>Helpdesk Support</h3>
          <p>Fast, friendly IT support for your employees. Password resets, software issues, hardware questions — we're a call away.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="managed-services.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">🔄</div>
          <h3>Patch Management</h3>
          <p>Automated OS, application, and firmware updates — tested and applied on a schedule that works for your business.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="managed-services.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">💾</div>
          <h3>Backup &amp; Disaster Recovery</h3>
          <p>Automated backups with tested recovery procedures. Your data is protected and recoverable.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="managed-services.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">☁️</div>
          <h3>Microsoft 365 Management</h3>
          <p>Exchange Online, Teams, SharePoint, OneDrive — user provisioning, security, and administration handled for you.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="managed-services.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">🌐</div>
          <h3>Network Management</h3>
          <p>Firewalls, switches, Wi-Fi, and VPN — designed, deployed, and managed to keep your business connected.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="managed-services.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">🧠</div>
          <h3>Virtual CIO (vCIO)</h3>
          <p>Strategic IT leadership — technology roadmaps, budgeting, vendor evaluation, and quarterly business reviews.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CYBERSECURITY SERVICES -->
  <section style="background:var(--surface);">
    <div class="section-inner">
      <div style="text-align:center;max-width:640px;margin:0 auto 2rem;">
        <div class="section-label">Cybersecurity — Powered by Coro</div>
        <h2>Enterprise-Grade <span class="grad">Cyber Protection</span></h2>
      </div>
      <div class="products-grid">
        <a href="cybersecurity.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">💻</div>
          <h3>Endpoint Protection</h3>
          <p>Next-gen antivirus and EDR for every device. Automatic detection, containment, and remediation of threats.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="cybersecurity.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">📧</div>
          <h3>Email Security</h3>
          <p>Block phishing, business email compromise, and malware before they reach your inbox.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="cybersecurity.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">🛡️</div>
          <h3>Cloud App &amp; Network Security</h3>
          <p>Protect your cloud apps, enforce Zero Trust access, and filter DNS — all from a single platform.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- VERKADA SERVICES -->
  <section>
    <div class="section-inner">
      <div style="text-align:center;max-width:640px;margin:0 auto 2rem;">
        <div class="section-label">Physical Security — Verkada Gold Partner</div>
        <h2>Full-Stack Security <span class="grad">Services</span></h2>
      </div>
      <div class="products-grid">
        <div class="product-card">
          <div class="pcard-icon">🛒</div>
          <h3>Verkada Product Resale</h3>
          <p>Purchase any Verkada hardware or software license through Blue Cap IT at competitive pricing. As an official Verkada partner, we ensure you get genuine products with full manufacturer warranties.</p>
        </div>
        <div class="product-card">
          <div class="pcard-icon">🔩</div>
          <h3>Professional Installation</h3>
          <p>Our certified technicians handle all physical installation — camera mounting, cable routing, door hardware, network drops, and device commissioning. We leave your site clean and your system fully operational.</p>
        </div>
        <div class="product-card">
          <div class="pcard-icon">☁️</div>
          <h3>Cloud Onboarding &amp; Configuration</h3>
          <p>We provision every device in Verkada Command, configure user accounts and permissions, set up alerts, and build the dashboard structure that makes sense for your organization.</p>
        </div>
        <div class="product-card">
          <div class="pcard-icon">📋</div>
          <h3>License &amp; Subscription Management</h3>
          <p>We track your Verkada software subscriptions, notify you ahead of renewal dates, and handle all licensing paperwork — so you never face an unexpected lapse in coverage.</p>
        </div>
        <div class="product-card">
          <div class="pcard-icon">🎓</div>
          <h3>Staff Training</h3>
          <p>On-site or remote training sessions for your team. We cover live viewing, footage search and export, access control management, alert configuration, and everything in between.</p>
        </div>
        <div class="product-card">
          <div class="pcard-icon">📞</div>
          <h3>Ongoing Technical Support</h3>
          <p>Call us at (410) 858-4031 or email <a href="mailto:info@bluecapit.com" style="color:var(--blue);">info@bluecapit.com</a> for troubleshooting, system expansions, user changes, and anything else that comes up. We're your long-term Verkada support partner.</p>
        </div>
        <div class="product-card">
          <div class="pcard-icon">📐</div>
          <h3>Site Assessment &amp; Design</h3>
          <p>Not sure what you need? We'll walk your facility, identify coverage gaps, and provide a complete system design recommendation with itemized pricing — completely free.</p>
        </div>
        <div class="product-card">
          <div class="pcard-icon">🔄</div>
          <h3>System Upgrades &amp; Migrations</h3>
          <p>Replacing an old analog or IP camera system? We manage the full migration to Verkada — including legacy hardware removal, new installation, and data transition.</p>
        </div>
        <div class="product-card">
          <div class="pcard-icon">📡</div>
          <h3>Network &amp; Infrastructure</h3>
          <p>Need new network drops, PoE switches, or wireless infrastructure to support your Verkada deployment? Blue Cap IT handles the full IT stack, not just the cameras.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HUNTRESS SERVICES -->
  <section style="background:var(--surface);">
    <div class="section-inner">
      <div style="text-align:center;max-width:640px;margin:0 auto 2rem;">
        <div class="section-label">Managed Security — Huntress Partner</div>
        <h2>24/7 SOC-Backed <span class="grad">Security Services</span></h2>
      </div>
      <div class="products-grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr));max-width:1000px;margin:0 auto;">
        <a href="huntress-edr.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">💻</div>
          <h3>Managed EDR</h3>
          <p>24/7 endpoint detection and response with behavioral analytics and automated remediation. 8-minute mean time to respond.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="huntress-itdr.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">🔐</div>
          <h3>Managed ITDR</h3>
          <p>Identity threat detection for Microsoft 365 and Google Workspace. Stops account takeovers and BEC attacks.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="huntress-siem.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">📊</div>
          <h3>Managed SIEM</h3>
          <p>Security log management and compliance reporting, fully managed by SOC experts at a predictable price.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="huntress-sat.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">🎓</div>
          <h3>Security Awareness Training</h3>
          <p>Engaging training with hands-on simulations built on real-world threat intelligence.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- SPOT.AI SERVICES -->
  <section>
    <div class="section-inner">
      <div style="text-align:center;max-width:640px;margin:0 auto 2rem;">
        <div class="section-label">Video Intelligence — spot.ai Partner</div>
        <h2>AI-Powered <span class="grad">Video Services</span></h2>
      </div>
      <div class="products-grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr));max-width:1000px;margin:0 auto;">
        <a href="spotai-cameras.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">📷</div>
          <h3>AI Camera Deployment</h3>
          <p>Premium IP cameras at no cost, or upgrade existing cameras with AI analytics. Camera-agnostic platform.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="spotai-ivr.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">💾</div>
          <h3>Intelligent Video Recorder</h3>
          <p>Edge AI hardware with 30-90 day local storage, supporting up to 32 cameras per appliance.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="spotai-video-intelligence.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">🧠</div>
          <h3>Video Intelligence</h3>
          <p>AI-powered search, people counting, license plate recognition, and operational analytics.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="spotai-alerts.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">🔔</div>
          <h3>Real-Time Alerts</h3>
          <p>Custom triggers for security incidents, safety violations, and operational anomalies with video attached.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- METER SERVICES -->
  <section style="background:var(--surface);">
    <div class="section-inner">
      <div style="text-align:center;max-width:640px;margin:0 auto 2rem;">
        <div class="section-label">Enterprise Networking — Meter Partner</div>
        <h2>Network as a <span class="grad">Service</span></h2>
      </div>
      <div class="products-grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr));max-width:1000px;margin:0 auto;">
        <a href="meter-switches.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">🔀</div>
          <h3>Switches</h3>
          <p>S-Series switches with PoE++, 2.5GbE, and 25Gbps uplinks. Silent, compact, cloud-managed.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="meter-access-points.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">📶</div>
          <h3>Wi-Fi 7 Access Points</h3>
          <p>Tri-band access points with custom circuitry for blazing-fast wireless performance.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="meter-firewalls.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">🔥</div>
          <h3>Firewalls</h3>
          <p>In-house designed firewalls with automatic failover, VPN, SD-WAN, and DNS security.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
        <a href="meter-dashboard.html" class="product-card" style="text-decoration:none;color:inherit;">
          <div class="pcard-icon">🖥️</div>
          <h3>Meter Dashboard</h3>
          <p>AI-powered network management with natural language controls and real-time monitoring.</p>
          <span class="pcard-arrow">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="section-label">Let's Talk</div>
    <h2>Ready to Work with<br/><span class="grad">Blue Cap IT?</span></h2>
    <p>Contact us for a free consultation. We'll listen to your needs, assess your situation, and recommend the right solution — managed IT, cybersecurity, physical security, video intelligence, or networking.</p>
    <div class="btn-group">
      <a href="contact.html" class="btn-primary">Contact Us Today</a>
      <a href="tel:4108584031" class="btn-ghost">📞 (410) 858-4031</a>
      <a href="mailto:info@bluecapit.com" class="btn-ghost">✉️ info@bluecapit.com</a>
    </div>
  </div>
</MainLayout>
