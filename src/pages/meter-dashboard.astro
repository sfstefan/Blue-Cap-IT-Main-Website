---
import MainLayout from '../layouts/MainLayout.astro';
import { Icon } from 'astro-icon/components';
---
<MainLayout title="Meter Dashboard & Command | Blue Cap IT — Meter Partner" description="Meter Dashboard and Command give you real-time visibility and AI-powered control of your entire network. Custom dashboards, natural language controls, and collaborative tools — all in one platform.">
  <div class="inner-hero">
    <div class="section-inner">
      <img src="/meter/Meter-purple.png" alt="Meter" style="max-height:60px;width:auto;margin-bottom:1.5rem;"/>
      <div class="crumbs"><a href="index.html">Home</a> <span>/</span> <a href="meter.html">Networking</a> <span>/</span> Dashboard &amp; Command</div>
      <div class="section-label">Meter Software</div>
      <h1>Meter <span class="grad">Dashboard &amp; Command</span></h1>
      <p class="section-sub">Real-time visibility into every corner of your network. The Meter Dashboard gives you granular control, while Meter Command adds AI-powered intelligence — ask a question, describe a task, or request a custom dashboard, and Command builds it on the fly.</p>
    </div>
  </div>

  <!-- DASHBOARD -->
  <section>
    <div class="section-inner">
      <div class="why-grid">
        <div>
          <img src="/meter/dashboard-network.webp" alt="Meter Dashboard" style="width:100%;max-width:500px;border-radius:0.75rem;margin-bottom:1.5rem;" />
          <div class="section-label">Meter Dashboard</div>
          <h2>See Everything. <span class="grad">Control Everything.</span></h2>
          <p class="section-sub">The Meter Dashboard is your command center for the entire network. Monitor device health, configure settings, troubleshoot issues, and track performance — all from a single, intuitive interface. Your IT team has full autonomy to configure as needed, with real-time visibility that expedites troubleshooting.</p>
          <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
            <a href="contact.html" class="btn-primary">Get a Free Quote</a>
            <a href="tel:4108584031" class="btn-ghost">Call (410) 858-4031</a>
          </div>
        </div>
        <ul class="why-list">
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:bar-chart-3" /></div>
            <div><h4>Real-Time Monitoring</h4><p>Live dashboards update in real time, showing device status, traffic patterns, client health, and network performance — always current, never stale.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:target" /></div>
            <div><h4>Granular Control</h4><p>Configure VLANs, firewall rules, DNS settings, SSIDs, port assignments, and more — all from the dashboard without touching a CLI.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:bell-ring" /></div>
            <div><h4>Smart Alerts</h4><p>Customizable alerts notify your team of important network events — device outages, performance degradation, security incidents, and more.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:users" /></div>
            <div><h4>Team Collaboration</h4><p>Share views, dashboards, and insights with team members or stakeholders. Everyone sees the same data — no silos, no miscommunication.</p></div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- METER COMMAND -->
  <section style="background:var(--surface);">
    <div class="section-inner">
      <div style="text-align:center;max-width:640px;margin:0 auto 2rem;">
        <div class="section-label">Meter Command</div>
        <h2>AI-Powered <span class="grad">Network Intelligence</span></h2>
        <p class="section-sub" style="margin:0.8rem auto 0;text-align:center;">Meter Command uses generative AI to transform how you interact with your network. Ask a question in plain English and Command fetches live data, performs tasks, and builds custom dashboards — on the fly and tailored to you.</p>
      </div>
      <div class="products-grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));">
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon"><Icon name="lucide:message-square" /></div>
          <h3>Natural Language</h3>
          <p>Ask "How many devices are on the guest network?" or "Show me bandwidth usage by floor" — Command understands and delivers.</p>
        </div>
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon"><Icon name="lucide:trending-up" /></div>
          <h3>Custom Dashboards</h3>
          <p>Request a dashboard and Command builds it from scratch — drag-and-drop graphs, charts, tables, and metrics tailored to your needs.</p>
        </div>
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon"><Icon name="lucide:zap" /></div>
          <h3>Task Automation</h3>
          <p>Describe a task like "Block this device" or "Create a VLAN for IoT devices" and Command executes it — making real-time API calls on your behalf.</p>
        </div>
        <div class="product-card" style="text-align:center;">
          <div class="pcard-icon"><Icon name="lucide:image" /></div>
          <h3>Canvas View</h3>
          <p>A flexible, zoomable interface that lets you arrange network elements spatially. Understand complex topologies at a glance with visual organization.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section>
    <div class="section-inner" style="text-align:center;padding:4rem 1.5rem;">
      <h2>Experience <span class="grad">Smarter Networking</span></h2>
      <p class="section-sub" style="max-width:600px;margin:0.8rem auto 2rem;text-align:center;">Contact Blue Cap IT to see the Meter Dashboard and Command in action. We'll show you how AI-powered network management can transform your IT operations.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="contact.html" class="btn-primary">Get a Free Quote</a>
        <a href="tel:4108584031" class="btn-ghost">Call (410) 858-4031</a>
      </div>
    </div>
  </section>
</MainLayout>
