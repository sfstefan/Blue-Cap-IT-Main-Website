---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Verkada Command Platform | Blue Cap IT — Gold Partner">
  <div class="inner-hero">
    <div class="section-inner">
      <div class="crumbs"><a href="index.html">Home</a> <span>/</span> <a href="verkada.html">Verkada Solutions</a> <span>/</span> Verkada Command</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;">
        <div>
          <div class="section-label">Verkada Platform</div>
          <h1>Verkada <span class="grad">Command</span></h1>
          <p class="section-sub">The unified cloud platform that ties every Verkada device together. One login. One dashboard. Complete physical security visibility.</p>
          <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
            <a href="contact.html" class="btn-primary">Get Started with Verkada</a>
            <a href="tel:4108584031" class="btn-ghost btn-sm">📞 (410) 858-4031</a>
          </div>
        </div>
        <img src="/logo.svg" alt="Blue Cap IT" class="feature-img"/>
      </div>
    </div>
  </div>

  <section>
    <div class="section-inner">
      <div class="feature-list">
        <div class="feature-row">
          <div class="feature-visual">
            <div class="feature-visual-bg"></div>
            <img src="/logo.svg" alt="Blue Cap IT" style="max-width:400px;width:100%;filter:drop-shadow(0 16px 48px rgba(0,0,0,0.5));border-radius:8px;"/>
          </div>
          <div class="feature-content">
            <h3>One Dashboard for Everything</h3>
            <p>Verkada Command unifies cameras, access control, sensors, alarms, and intercoms in a single browser-based interface. No switching between apps or systems.</p>
            <ul class="feature-bullets">
              <li>Live camera feeds and archived footage</li>
              <li>Real-time access control events and door status</li>
              <li>Sensor readings and environmental alerts</li>
              <li>Alarm status and incident history</li>
              <li>Visitor logs and intercom activity</li>
            </ul>
          </div>
        </div>
        <div class="feature-row rev">
          <div class="feature-visual"><div class="feature-visual-bg"></div><div class="big-icon">🛡️</div></div>
          <div class="feature-content">
            <h3>Zero IT Infrastructure Required</h3>
            <p>Verkada Command is 100% cloud-hosted. No on-site servers, no VPNs, no complex network configuration. Devices plug in and appear in your dashboard automatically.</p>
            <ul class="feature-bullets">
              <li>No NVR, DVR, or on-premise servers</li>
              <li>No VPN required for remote access</li>
              <li>Automatic firmware updates by Verkada</li>
              <li>99.9% uptime SLA from Verkada</li>
              <li>End-to-end encrypted data transmission</li>
            </ul>
          </div>
        </div>
        <div class="feature-row">
          <div class="feature-visual"><div class="feature-visual-bg"></div><div class="big-icon">👥</div></div>
          <div class="feature-content">
            <h3>Enterprise-Grade User Management</h3>
            <p>Granular role-based access control means every user sees only what they need to. Integrate with your existing identity provider via SAML SSO.</p>
            <ul class="feature-bullets">
              <li>Custom roles and permission levels</li>
              <li>SAML 2.0 SSO (Okta, Azure AD, Google)</li>
              <li>Multi-organization and multi-site support</li>
              <li>Full admin audit trail</li>
              <li>Mobile app for iOS &amp; Android</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="section-inner" style="text-align:center;max-width:800px;margin:0 auto;padding:4rem 1.5rem;">
      <div class="section-label">See It in Action</div>
      <h2>Searching in <span class="grad">Verkada Command</span></h2>
      <p class="section-sub" style="text-align:center;margin:0.8rem auto 2rem;">See how easy it is to search across all your cameras, doors, and devices from one unified dashboard.</p>
      <div style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:1rem;box-shadow:0 8px 32px rgba(0,0,0,0.3);">
        <iframe src="https://www.youtube.com/embed/H4f0hVifcWs" title="Searching in Verkada Command" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;"></iframe>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="section-label">See It in Action</div>
    <h2>Experience Verkada Command<br/><span class="grad">with Blue Cap IT</span></h2>
    <p>We'll walk you through a live Verkada Command demo and show you exactly how it would look with your organization's devices and layout.</p>
    <div class="btn-group">
      <a href="contact.html" class="btn-primary">Schedule a Live Demo</a>
      <a href="tel:4108584031" class="btn-ghost">📞 (410) 858-4031</a>
      <a href="mailto:info@bluecapit.com" class="btn-ghost">✉️ info@bluecapit.com</a>
    </div>
  </div>
</MainLayout>
