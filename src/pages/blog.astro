---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---
<MainLayout title="News & Blog | Blue Cap IT" description="Latest news, security insights, and product updates from Blue Cap IT — your official Verkada Gold Partner.">

  <section class="inner-hero">
    <div class="section-inner">
      <span class="crumbs"><a href="index.html">Home</a> <span>/</span> News</span>
      <h1>News & <span class="grad">Blog</span></h1>
      <p class="hero-sub" style="margin-top:1rem;">Security insights, product updates, and company news from Blue Cap IT.</p>
    </div>
  </section>

  <!-- SUBSCRIBE BANNER -->
  <section class="subscribe-band" id="subscribe">
    <div class="section-inner">
      <div class="subscribe-box">
        <div class="subscribe-text">
          <h2>Stay in the Loop</h2>
          <p>Get the latest Verkada product updates, security insights, and Blue Cap IT news delivered straight to your inbox.</p>
        </div>
        <form class="subscribe-form" id="subscribeForm">
          <div class="subscribe-fields">
            <input type="text" name="firstName" placeholder="Your Name *" required />
            <input type="text" name="companyName" placeholder="Company Name" />
            <input type="email" name="email" placeholder="Email Address *" required />
          </div>
          <button type="submit" class="btn-primary">Subscribe</button>
          <p class="subscribe-note">No spam, ever. Unsubscribe anytime.</p>
          <div class="subscribe-message" id="subscribeMessage"></div>
        </form>
      </div>
    </div>
  </section>

  <section style="background:var(--surface);">
    <div class="section-inner">
      {posts.length === 0 && <p style="color:var(--text-muted);text-align:center;">No posts yet — check back soon!</p>}
      <div class="blog-grid">
        {posts.map((post) => (
          <a href={`blog/${post.id}.html`} class="blog-card">
            <div class="blog-card-date">
              {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="blog-card-link">Read more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="section-label">Stay Connected</div>
    <h2>Have a Question or Topic Suggestion?</h2>
    <p>We'd love to hear from you. Reach out and let us know what security topics matter most to your business.</p>
    <div style="display:flex;gap:0.8rem;flex-wrap:wrap;justify-content:center;">
      <a href="contact.html" class="btn-primary">Contact Us</a>
    </div>
  </section>

</MainLayout>

<script is:inline>
  document.getElementById('subscribeForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('button[type="submit"]');
    const msg = document.getElementById('subscribeMessage');
    const data = {
      firstName: form.firstName.value,
      companyName: form.companyName.value,
      email: form.email.value,
    };
    btn.disabled = true;
    btn.textContent = 'Subscribing...';
    msg.textContent = '';
    msg.className = 'subscribe-message';
    try {
      const res = await fetch('/.netlify/functions/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = await res.json();
      if (res.ok) {
        msg.textContent = result.message;
        msg.classList.add('success');
        form.reset();
      } else {
        msg.textContent = result.error || 'Something went wrong. Please try again.';
        msg.classList.add('error');
      }
    } catch {
      msg.textContent = 'Something went wrong. Please try again.';
      msg.classList.add('error');
    }
    btn.disabled = false;
    btn.textContent = 'Subscribe';
  });
</script>
