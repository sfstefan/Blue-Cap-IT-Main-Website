---
import MainLayout from '../layouts/MainLayout.astro';
import { Icon } from 'astro-icon/components';
---
<MainLayout title="About Blue Cap IT | Managed IT, Cybersecurity & Verkada Gold Partner" description="Blue Cap IT is a full-service managed IT provider, Verkada Gold Partner, Coro cybersecurity partner, and Meter networking partner. Learn about our team, mission, and approach to IT services.">
  <div class="inner-hero">
    <div class="section-inner">
      <div class="crumbs"><a href="index.html">Home</a> <span>/</span> About</div>
      <div class="section-label">Who We Are</div>
      <h1>About <span class="grad">Blue Cap IT</span></h1>
      <p class="section-sub">A technology company providing managed IT services, cybersecurity, and physical security solutions. We combine local service with enterprise-grade technology to deliver exceptional results for our clients.</p>
    </div>
  </div>

  <section>
    <div class="section-inner">
      <div class="why-grid">
        <div>
          <div class="section-label">Our Mission</div>
          <h2>Making Enterprise Technology<br/><span class="grad">Accessible.</span></h2>
          <p class="section-sub">Blue Cap IT was founded with a simple mission: bring enterprise-grade IT services, cybersecurity, and physical security to businesses of all sizes — with the personal service of a local partner.</p>
          <p class="section-sub" style="margin-top:1rem;">As a managed service provider, Coro cybersecurity partner, and Verkada Gold Partner, we provide the complete technology stack your business needs. We handle everything from IT strategy and helpdesk support to cybersecurity deployment and physical security installation.</p>
          <div class="verkada-gold-section">
            <img src="/verkada-gold-partner-badge.png" alt="Verkada Gold Partner" style="height:52px;width:auto;flex-shrink:0;"/>
            <p><strong>Verkada Gold Partner Program Member.</strong> This status reflects our commitment to Verkada's platform, our technical expertise, and the trust our clients place in us.</p>
          </div>
          <div style="margin-top:2rem;">
            <a href="contact.html" class="btn-primary">Contact Our Team</a>
          </div>
        </div>
        <ul class="why-list">
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:monitor" /></div>
            <div><h4>Managed Service Provider</h4><p>We serve as your complete outsourced IT department — remote monitoring, helpdesk, patch management, backup, Microsoft 365, network management, and vCIO services.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:shield" /></div>
            <div><h4>Coro Cybersecurity Partner</h4><p>As a Coro Partner, we deploy and manage all-in-one cybersecurity — endpoint protection, email security, cloud app security, network protection, and security awareness training.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:star" /></div>
            <div><h4>Verkada Gold Partner</h4><p>Official Verkada Gold Partner status — full product catalog, partner pricing, manufacturer warranties, and technical support for physical security solutions.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:map-pin" /></div>
            <div><h4>Local, Responsive Service</h4><p>We're local. Our team provides the hands-on support and quick response times that remote providers simply can't match.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:handshake" /></div>
            <div><h4>Relationship-Driven Support</h4><p>When you call (410) 858-4031 or email <a href="mailto:info@bluecapit.com" style="color:var(--blue);">info@bluecapit.com</a>, you reach a real person who knows your system. We build long-term partnerships, not just one-time transactions.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:lock" /></div>
            <div><h4>Security-First Mindset</h4><p>We understand that physical security is serious. We approach every project with the rigor, care, and professionalism that protecting your people and assets demands.</p></div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- PRODUCT FAMILY SHOT -->
  <section style="padding:1rem 4% 5rem;background:var(--off-white);">
    <div class="section-inner" style="text-align:center;">
      <div class="section-label">What We Deliver</div>
      <h2>The Full Verkada <span class="grad">Platform</span></h2>
      <p class="section-sub" style="margin:0 auto 2rem;">From cameras and access control to sensors, alarms, intercom, and wireless — Blue Cap IT delivers the complete Verkada ecosystem.</p>
      <img src="/250228_Family_Portrait_Square0120_Levels-Edit.png" alt="Verkada Product Family" class="img-hero-band"/>
    </div>
  </section>

  <!-- PARTNER SECTION -->
  <section style="background:var(--surface);">
    <div class="section-inner" style="text-align:center;max-width:700px;margin:0 auto;">
      <div class="section-label">Our Partnerships</div>
      <h2>Trusted <span class="grad">Technology Partners</span></h2>
      <p class="section-sub" style="text-align:center;margin:0.8rem auto 1.5rem;">Blue Cap IT partners with industry leaders to bring the best technology to our clients. Our partnerships mean you get enterprise-grade solutions backed by world-class support.</p>
      <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:2rem;margin:0 auto 2rem;">
        <img src="/verkada-gold-partner-badge.png" alt="Verkada Gold Partner" style="height:70px;width:auto;"/>
        <img src="/Coro/coro-logo-wide-indigo.png" alt="Coro Partner" style="height:40px;width:auto;"/>
        <img src="/Huntress/huntress-logo-teal.png" alt="Huntress Partner" style="height:36px;width:auto;"/>
        <img src="/spotai/spotai-logo.png" alt="spot.ai Partner" style="height:32px;width:auto;"/>
        <img src="/meter/Meter-purple.png" alt="Meter Partner" style="height:32px;width:auto;"/>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1.2rem;max-width:900px;margin:0 auto;">
        <div class="spec-card" style="text-align:center;padding:1.8rem 1rem;"><div style="font-size:2rem;margin-bottom:0.7rem;color:var(--elec);"><Icon name="lucide:medal" /></div><div style="font-family:'Sora',sans-serif;font-weight:700;font-size:0.9rem;color:var(--navy);margin-bottom:0.3rem;">Verkada Gold Partner</div><div style="font-size:0.8rem;color:var(--text-muted);">Physical Security Platform</div></div>
        <div class="spec-card" style="text-align:center;padding:1.8rem 1rem;"><div style="font-size:2rem;margin-bottom:0.7rem;color:var(--elec);"><Icon name="lucide:shield" /></div><div style="font-family:'Sora',sans-serif;font-weight:700;font-size:0.9rem;color:var(--navy);margin-bottom:0.3rem;">Coro Partner</div><div style="font-size:0.8rem;color:var(--text-muted);">All-in-One Cybersecurity</div></div>
        <div class="spec-card" style="text-align:center;padding:1.8rem 1rem;"><div style="font-size:2rem;margin-bottom:0.7rem;color:var(--elec);"><Icon name="lucide:target" /></div><div style="font-family:'Sora',sans-serif;font-weight:700;font-size:0.9rem;color:var(--navy);margin-bottom:0.3rem;">Huntress Partner</div><div style="font-size:0.8rem;color:var(--text-muted);">24/7 Managed Security</div></div>
        <div class="spec-card" style="text-align:center;padding:1.8rem 1rem;"><div style="font-size:2rem;margin-bottom:0.7rem;color:var(--elec);"><Icon name="lucide:video" /></div><div style="font-family:'Sora',sans-serif;font-weight:700;font-size:0.9rem;color:var(--navy);margin-bottom:0.3rem;">spot.ai Partner</div><div style="font-size:0.8rem;color:var(--text-muted);">AI Video Intelligence</div></div>
        <div class="spec-card" style="text-align:center;padding:1.8rem 1rem;"><div style="font-size:2rem;margin-bottom:0.7rem;color:var(--elec);"><Icon name="lucide:globe" /></div><div style="font-family:'Sora',sans-serif;font-weight:700;font-size:0.9rem;color:var(--navy);margin-bottom:0.3rem;">Meter Partner</div><div style="font-size:0.8rem;color:var(--text-muted);">Enterprise Networking</div></div>
        <div class="spec-card" style="text-align:center;padding:1.8rem 1rem;"><div style="font-size:2rem;margin-bottom:0.7rem;color:var(--elec);"><Icon name="lucide:monitor" /></div><div style="font-family:'Sora',sans-serif;font-weight:700;font-size:0.9rem;color:var(--navy);margin-bottom:0.3rem;">Managed Services</div><div style="font-size:0.8rem;color:var(--text-muted);">Complete IT Management</div></div>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="section-label">Work With Us</div>
    <h2>Let's Secure Your<br/><span class="grad">Business Together</span></h2>
    <p>Contact Blue Cap IT today to start a conversation about your security needs. Free consultations, transparent pricing, no pressure.</p>
    <div class="btn-group">
      <a href="contact.html" class="btn-primary">Get in Touch</a>
      <a href="tel:4108584031" class="btn-ghost"><Icon name="lucide:phone" /> (410) 858-4031</a>
      <a href="mailto:info@bluecapit.com" class="btn-ghost"><Icon name="lucide:mail" /> info@bluecapit.com</a>
    </div>
  </div>
</MainLayout>
