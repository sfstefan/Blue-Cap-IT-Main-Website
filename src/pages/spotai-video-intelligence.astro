---
import MainLayout from '../layouts/MainLayout.astro';
import { Icon } from 'astro-icon/components';
---
<MainLayout title="Video Intelligence | spot.ai Analytics & Search — Blue Cap IT" description="spot.ai Video Intelligence uses deep learning to search, analyze, and extract insights from your camera footage. Object detection, people counting, license plate recognition, and trend reporting — all AI-powered.">
  <div class="inner-hero">
    <div class="section-inner">
      <img src="/spotai/spotai-logo.png" alt="spot.ai" style="max-height:50px;width:auto;margin-bottom:1.5rem;"/>
      <div class="crumbs"><a href="index.html">Home</a> <span>/</span> <a href="spotai.html">spot.ai</a> <span>/</span> Video Intelligence</div>
      <div class="section-label">spot.ai Software</div>
      <h1>Video <span class="grad">Intelligence</span></h1>
      <p class="section-sub">Turn hours of footage into instant answers. spot.ai's Video Intelligence uses deep-learning models to search video by natural language, detect objects and people, recognize license plates, count traffic, and surface trends — without manual tagging or metadata.</p>
    </div>
  </div>

  <section>
    <div class="section-inner">
      <div class="why-grid">
        <div>
          <div class="section-label">AI-Powered Insights</div>
          <h2>Search. Analyze. <span class="grad">Understand.</span></h2>
          <p class="section-sub">spot.ai indexes every frame of video with deep-learning models — classifying people, vehicles, objects, and motion. That means you can search your footage the way you search the web, get instant answers, and discover patterns you'd never find manually.</p>
          <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
            <a href="contact.html" class="btn-primary">Get a Free Quote</a>
            <a href="tel:4108584031" class="btn-ghost">Call (410) 858-4031</a>
          </div>
        </div>
        <ul class="why-list">
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:search" /></div>
            <div><h4>Natural Language Search</h4><p>Search your video footage using plain English — "red truck in parking lot" or "person at back door after 10pm." spot.ai finds it instantly.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:users" /></div>
            <div><h4>People Counting &amp; Traffic</h4><p>Automatically count people entering and exiting locations. Track foot traffic patterns, peak hours, and occupancy trends over time.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:car" /></div>
            <div><h4>License Plate Recognition</h4><p>Automatically read and log license plates from your camera footage. Search by plate number to find specific vehicles across all your cameras.</p></div>
          </li>
          <li class="why-item">
            <div class="why-icon"><Icon name="lucide:trending-up" /></div>
            <div><h4>Trend Reporting</h4><p>AI-generated reports on traffic patterns, safety incidents, operational metrics, and anomalies — delivered automatically to your dashboard.</p></div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section>
    <div class="section-inner" style="text-align:center;padding:4rem 1.5rem;">
      <h2>Unlock the Intelligence <span class="grad">In Your Video</span></h2>
      <p class="section-sub" style="max-width:600px;margin:0.8rem auto 2rem;text-align:center;">Contact Blue Cap IT to see spot.ai's Video Intelligence in action. We'll show you the insights hiding in your existing camera footage.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="contact.html" class="btn-primary">Get a Free Quote</a>
        <a href="tel:4108584031" class="btn-ghost">Call (410) 858-4031</a>
      </div>
    </div>
  </section>
</MainLayout>
