---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Page Not Found | Blue Cap IT" description="The page you're looking for doesn't exist. Browse our managed IT, cybersecurity, physical security, and networking solutions.">
  <div class="inner-hero">
    <div class="section-inner" style="text-align:center;">
      <div style="font-size:6rem;margin-bottom:1rem;">404</div>
      <h1>Page <span class="grad">Not Found</span></h1>
      <p class="section-sub" style="text-align:center;margin:1rem auto 2rem;max-width:500px;">The page you're looking for doesn't exist or has been moved. Let's get you back on track.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="index.html" class="btn-primary">Back to Homepage</a>
        <a href="contact.html" class="btn-ghost">Contact Us</a>
      </div>
    </div>
  </div>

  <section style="background:var(--surface);">
    <div class="section-inner">
      <div style="text-align:center;max-width:640px;margin:0 auto 2rem;">
        <h2>Looking for <span class="grad">Something?</span></h2>
      </div>
      <div class="products-grid" style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr));max-width:900px;margin:0 auto;">
        <a href="managed-services.html" class="product-card" style="text-decoration:none;color:inherit;text-align:center;">
          <div class="pcard-icon">🖥️</div>
          <h3>Managed IT</h3>
          <span class="pcard-arrow">View services →</span>
        </a>
        <a href="cybersecurity.html" class="product-card" style="text-decoration:none;color:inherit;text-align:center;">
          <div class="pcard-icon">🛡️</div>
          <h3>Coro Cybersecurity</h3>
          <span class="pcard-arrow">View solutions →</span>
        </a>
        <a href="huntress.html" class="product-card" style="text-decoration:none;color:inherit;text-align:center;">
          <div class="pcard-icon">🎯</div>
          <h3>Huntress Security</h3>
          <span class="pcard-arrow">View solutions →</span>
        </a>
        <a href="verkada.html" class="product-card" style="text-decoration:none;color:inherit;text-align:center;">
          <div class="pcard-icon">📷</div>
          <h3>Verkada Security</h3>
          <span class="pcard-arrow">View products →</span>
        </a>
        <a href="spotai.html" class="product-card" style="text-decoration:none;color:inherit;text-align:center;">
          <div class="pcard-icon">📹</div>
          <h3>spot.ai Video</h3>
          <span class="pcard-arrow">View solutions →</span>
        </a>
        <a href="meter.html" class="product-card" style="text-decoration:none;color:inherit;text-align:center;">
          <div class="pcard-icon">🌐</div>
          <h3>Meter Networking</h3>
          <span class="pcard-arrow">View products →</span>
        </a>
      </div>
    </div>
  </section>
</MainLayout>
